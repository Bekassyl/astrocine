---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { marked } from 'marked';

const aboutEntries = await getCollection('about');
const aboutContent = aboutEntries[0];

const bodyChunks = aboutContent ? aboutContent.body.split(/\n(?=## )/) : [];
const introHTML = bodyChunks.length > 0 ? marked(bodyChunks[0]) : '';
const restHTML = bodyChunks.length > 1 ? marked(bodyChunks.slice(1).join('\n')) : '';

const experience = aboutContent?.data.experience ?? [];
const education = aboutContent?.data.education ?? [];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="About" description="Public health researcher specializing in evidence synthesis and pain medicine." />
		<style>
			.about-section {
				max-width: 640px;
				margin: 0 auto;
			}
			.about-avatar {
				width: 120px;
				height: 120px;
				border-radius: 50%;
				object-fit: cover;
				margin: 0 auto 1.5rem;
				display: block;
				border: 3px solid transparent;
				background: linear-gradient(135deg, var(--accent), #8b5cf6) padding-box,
							linear-gradient(135deg, var(--accent), #8b5cf6) border-box;
				box-shadow: 0 8px 30px rgba(59, 130, 246, 0.2);
			}
			.about-title {
				text-align: center;
				font-size: 1.75rem;
				font-weight: 700;
				color: var(--text-primary);
				margin-bottom: 0.25rem;
				letter-spacing: -0.02em;
			}
			.about-subtitle {
				text-align: center;
				font-size: 1rem;
				color: var(--accent);
				font-weight: 500;
				margin-bottom: 1.5rem;
			}
			.about-content {
				color: var(--text-secondary);
				line-height: 1.7;
			}
			.about-content h2 {
				font-size: 1.125rem;
				font-weight: 700;
				color: var(--text-primary);
				margin: 2rem 0 1rem;
				padding-top: 1.5rem;
				border-top: 1px solid var(--border-color);
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.about-content h2::before {
				content: '';
				width: 3px;
				height: 1.125rem;
				background: linear-gradient(180deg, var(--accent), #8b5cf6);
				border-radius: 2px;
			}
			.about-content h2:first-of-type {
				padding-top: 0;
				border-top: none;
				margin-top: 2rem;
			}
			.about-content p {
				margin-bottom: 0.75rem;
			}
			.about-content ul {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-wrap: wrap;
				gap: 0.75rem;
				justify-content: center;
			}
			.about-content li {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 72px;
				height: 72px;
				background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(139, 92, 246, 0.15));
				border-radius: 50%;
				font-size: 0.75rem;
				font-weight: 600;
				color: var(--accent);
				text-align: center;
				transition: all 0.25s ease;
				border: 1.5px solid rgba(59, 130, 246, 0.3);
			}
			.about-content li:hover {
				transform: translateY(-4px) scale(1.1);
				box-shadow: 0 8px 25px rgba(59, 130, 246, 0.4);
				border-color: var(--accent);
				background: linear-gradient(135deg, rgba(59, 130, 246, 0.25), rgba(139, 92, 246, 0.25));
			}
			.about-content a {
				display: flex;
				align-items: center;
				gap: 0.75rem;
				color: var(--text-secondary);
				text-decoration: none;
				padding: 0.75rem 1rem;
				border-radius: 0.75rem;
				background: var(--bg-secondary);
				transition: all 0.2s ease;
				margin-bottom: 0.75rem;
			}
			.about-content a:hover {
				color: var(--accent);
				background: rgba(59, 130, 246, 0.08);
				transform: translateY(-2px);
				text-decoration: none;
			}

			.cv-section-title {
				font-size: 1.125rem;
				font-weight: 700;
				color: var(--text-primary);
				margin: 2rem 0 1rem;
				padding-top: 1.5rem;
				border-top: 1px solid var(--border-color);
				display: flex;
				align-items: center;
				gap: 0.5rem;
			}
			.cv-section-title::before {
				content: '';
				width: 3px;
				height: 1.125rem;
				background: linear-gradient(180deg, var(--accent), #8b5cf6);
				border-radius: 2px;
			}
			.timeline {
				display: flex;
				flex-direction: column;
			}
			.timeline-item {
				display: flex;
				gap: 1rem;
			}
			.timeline-marker {
				display: flex;
				flex-direction: column;
				align-items: center;
				flex-shrink: 0;
			}
			.timeline-dot {
				width: 10px;
				height: 10px;
				border-radius: 50%;
				background: var(--accent);
				margin-top: 0.35rem;
				flex-shrink: 0;
			}
			.timeline-line {
				flex: 1;
				width: 2px;
				background: var(--border-color);
				margin: 0.35rem 0;
			}
			.timeline-item:last-child .timeline-line {
				display: none;
			}
			.timeline-content {
				flex: 1;
				min-width: 0;
				padding-bottom: 1.5rem;
			}
			.timeline-header {
				display: flex;
				justify-content: space-between;
				align-items: baseline;
				gap: 1rem;
				flex-wrap: wrap;
				margin: 0 0 0.15rem;
			}
			.timeline-title {
				font-size: 0.975rem;
				font-weight: 600;
				color: var(--text-primary);
				margin: 0;
			}
			.timeline-period {
				font-size: 0.8rem;
				font-weight: 600;
				color: var(--text-muted);
				white-space: nowrap;
			}
			.timeline-institution {
				font-size: 0.875rem;
				font-weight: 600;
				color: var(--accent);
				margin-bottom: 0.35rem;
			}
			.timeline-desc,
			.timeline-thesis {
				font-size: 0.875rem;
				color: var(--text-secondary);
				line-height: 1.6;
				margin: 0.25rem 0 0;
			}
			.timeline-thesis {
				font-style: italic;
			}


			html.dark .about-title {
				color: var(--text-primary);
			}
			html.dark .about-subtitle {
				color: var(--accent-light);
			}
			html.dark .about-content {
				color: var(--text-secondary);
			}
			html.dark .about-content h2 {
				color: var(--text-primary);
				border-top-color: var(--border-color);
			}
			html.dark .cv-section-title {
				color: var(--text-primary);
				border-top-color: var(--border-color);
			}
			html.dark .timeline-institution {
				color: var(--accent-light);
			}
			html.dark .about-content li {
				background: linear-gradient(135deg, rgba(96, 165, 250, 0.15), rgba(139, 92, 246, 0.15));
				color: var(--accent-light);
				border-color: rgba(96, 165, 250, 0.3);
			}
			html.dark .about-content li:hover {
				box-shadow: 0 8px 25px rgba(96, 165, 250, 0.4);
				border-color: var(--accent-light);
				background: linear-gradient(135deg, rgba(96, 165, 250, 0.25), rgba(139, 92, 246, 0.25));
			}
			html.dark .about-content a {
				color: var(--text-secondary);
				background: var(--bg-secondary);
			}
			html.dark .about-content a:hover {
				color: var(--accent-light);
				background: rgba(96, 165, 250, 0.1);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="about-section">
				{aboutContent && (
					<>
						<img
							class="about-avatar"
							src={`${import.meta.env.BASE_URL}avatar.png`}
							alt="Avatar"
						/>
						<h1 class="about-title">{aboutContent.data.name}</h1>
						<p class="about-subtitle">{aboutContent.data.title}</p>

						<article class="about-content" set:html={introHTML} />

						{experience.length > 0 && (
							<section class="cv-section">
								<h2 class="cv-section-title">Professional Experience</h2>
								<div class="timeline">
									{experience.map((item) => (
										<div class="timeline-item">
											<div class="timeline-marker">
												<span class="timeline-dot"></span>
												<span class="timeline-line"></span>
											</div>
											<div class="timeline-content">
												<div class="timeline-header">
													<h3 class="timeline-title">{item.role}</h3>
													<span class="timeline-period">{item.period}</span>
												</div>
												<div class="timeline-institution">{item.institution}</div>
												<p class="timeline-desc">{item.description}</p>
											</div>
										</div>
									))}
								</div>
							</section>
						)}

						{education.length > 0 && (
							<section class="cv-section">
								<h2 class="cv-section-title">Education</h2>
								<div class="timeline">
									{education.map((item) => (
										<div class="timeline-item">
											<div class="timeline-marker">
												<span class="timeline-dot"></span>
												<span class="timeline-line"></span>
											</div>
											<div class="timeline-content">
												<div class="timeline-header">
													<h3 class="timeline-title">{item.degree}</h3>
													<span class="timeline-period">{item.period}</span>
												</div>
												<div class="timeline-institution">{item.institution}</div>
												{item.thesis && <p class="timeline-thesis">Thesis: {item.thesis}</p>}
												{item.description && <p class="timeline-desc">{item.description}</p>}
											</div>
										</div>
									))}
								</div>
							</section>
						)}

						<article class="about-content" set:html={restHTML} />
					</>
				)}
			</div>

			
		</main>
		<Footer />
	</body>
</html>