---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE, AUTHOR_NAME, AUTHOR_TITLE, AUTHOR_DESCRIPTION } from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const recentPosts = allPosts.slice(0, 4);

const formatDate = (date: Date) => {
	const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
	const month = months[date.getMonth()];
	const day = date.getDate();
	return `${month} ${day}`;
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
	<body>
		<Header />
		<main>
			<section class="intro-section">
				<div class="intro-content">
					<h2 class="intro-title">Publications</h2>
					<p class="intro-description">A collection of research papers and scientific articles.</p>
				</div>
			</section>

			<section class="posts-section">
				<div class="section-header">
					<h2 class="section-title">Latest Posts</h2>
					<a href="/blog" class="section-link">View All →</a>
				</div>
				<ul class="post-list">
					{recentPosts.map((post) => (
						<li class="post-item">
							<a href={`/blog/${post.id}/`} class="post-link">
								<span class="post-date">{formatDate(post.data.pubDate)}</span>
								<h3 class="post-title">{post.data.title}</h3>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>